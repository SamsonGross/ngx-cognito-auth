{
  "name": "ngx-cognito-auth",
  "version": "1.0.0",
  "description": "Angular 21 library for AWS Cognito authentication using PKCE flow",
  "keywords": [
    "angular",
    "aws",
    "cognito",
    "authentication",
    "oauth2",
    "pkce"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/ngx-cognito-auth"
  },
  "license": "MIT",
  "peerDependencies": {
    "@angular/common": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@angular/router": ">=21.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/common": {
      "optional": false
    },
    "rxjs": {
      "optional": false
    }
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "module": "fesm2022/ngx-cognito-auth.mjs",
  "typings": "types/ngx-cognito-auth.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./types/ngx-cognito-auth.d.ts",
      "default": "./fesm2022/ngx-cognito-auth.mjs"
    }
  },
  "sideEffects": false

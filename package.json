{
  "name": "ngx-cognito-auth-workspace",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "set-env": "node scripts/set-env.js",
    "build:lib": "ng build ngx-cognito-auth",
    "watch:lib": "ng build ngx-cognito-auth --watch",
    "patch:lib": "npm version patch --prefix projects/ngx-cognito-auth && npm run build:lib",
    "minor:lib": "npm version minor --prefix projects/ngx-cognito-auth && npm run build:lib",
    "major:lib": "npm version major --prefix projects/ngx-cognito-auth && npm run build:lib",
    "release:patch": "npm run patch:lib && npm run lib:publish",
    "release:minor": "npm run minor:lib && npm run lib:publish",
    "release:major": "npm run major:lib && npm run lib:publish",
    "prebuild:demo": "node scripts/set-env.js",
    "build:demo": "ng build demo",
    "prestart": "node scripts/set-env.js",
    "start": "ng serve demo",
    "test": "ng test",
    "test:lib": "ng test ngx-cognito-auth",
    "test:demo": "ng test demo",
    "lint": "ng lint",
    "lib:package": "npm pack dist/ngx-cognito-auth",
    "lib:publish": "npm publish dist/ngx-cognito-auth --access public"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.0.0",
    "typescript": "~5.9.0"
  }
}